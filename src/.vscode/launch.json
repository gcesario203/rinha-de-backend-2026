{
  "version": "0.2.0",
  "configurations": [
    {
      "name": ".NET: Launch API Local",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build",
      "program": "${workspaceFolder}/anti-fraud-api/bin/Debug/net10.0/anti-fraud-api.dll",
      "args": [],
      "cwd": "${workspaceFolder}/anti-fraud-api",
      "stopAtEntry": false,
      "console": "internalConsole",
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "ASPNETCORE_URLS": "http://localhost:5000"
      }
    }
  ]
}